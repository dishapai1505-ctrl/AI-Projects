    "def rag_answer_with_memory(question):\n",
    "    docs = retriever.invoke(question)\n",
    "\n",
    "    context = \"\\n\\n\".join([\n",
    "        f\"Source {i+1}:\\n{doc.page_content}\"\n",
    "        for i, doc in enumerate(docs)\n",
    "    ])\n",
    "\n",
    "    history_text = \"\\n\".join([\n",
    "        f\"User: {item['user']}\\nAssistant: {item['assistant']}\"\n",
    "        for item in chat_history[-5:]\n",
    "    ])\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "You are a private document summarization assistant.\n",
    "\n",
    "Use the document context to answer the user's question.\n",
    "Use the chat history only to understand follow-up questions.\n",
    "If the answer is not in the context, say you do not know.\n",
    "\n",
    "Chat History:\n",
    "{history_text}\n",
    "\n",
    "Document Context:\n",
    "{context}\n",
    "\n",
    "User Question:\n",
    "{question}\n",
    "\n",
    "Answer:\n",
    "\"\"\"\n",
    "\n",
    "    answer = ask_groq(prompt)\n",
    "\n",
    "    chat_history.append({\n",
    "        \"user\": question,\n",
    "        \"assistant\": answer\n",
    "    })\n",
    "\n",
    "    return answer"
   ]
