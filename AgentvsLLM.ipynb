    "# CSV loading tool\n",
    "import pandas as pd\n",
    "\n",
    "@tool\n",
    "def load_csv(file_path: str) -> str:\n",
    "    \"\"\"\n",
    "    Loads a CSV file into the dataset cache.\n",
    "\n",
    "    Input:\n",
    "    file_path: path to the CSV file.\n",
    "\n",
    "    Output:\n",
    "    Dataset name, shape, and column names.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        df = pd.read_csv(file_path, on_bad_lines=\"skip\")\n",
    "\n",
    "        dataset_name = file_path.split(\"/\")[-1].replace(\".csv\", \"\")\n",
    "        DATASETS[dataset_name] = df\n",
    "\n",
    "        return f\"\"\"\n",
    "Loaded dataset: {dataset_name}\n",
    "Shape: {df.shape}\n",
    "Columns: {list(df.columns)}\n",
    "\n",
    "Note: Bad rows were skipped if the CSV had formatting issues.\n",
    "\"\"\"\n",
    "    except Exception as e:\n",
    "        return f\"Error loading CSV: {e}\""
   ]
