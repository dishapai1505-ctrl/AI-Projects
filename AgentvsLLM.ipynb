    "# summarization tool \n",
    "@tool\n",
    "def summarize_dataset(dataset_name: str) -> str:\n",
    "    \"\"\"\n",
    "    Generates a summary of a dataset.\n",
    "\n",
    "    Input:\n",
    "    dataset_name\n",
    "\n",
    "    Output:\n",
    "    Shape, columns, missing values, and descriptive statistics.\n",
    "    \"\"\"\n",
    "    \n",
    "    if dataset_name not in DATASETS:\n",
    "        return f\"Dataset '{dataset_name}' not found.\"\n",
    "\n",
    "    df = DATASETS[dataset_name]\n",
    "\n",
    "    summary = f\"\"\"\n",
    "Dataset: {dataset_name}\n",
    "\n",
    "Shape:\n",
    "{df.shape}\n",
    "\n",
    "Columns:\n",
    "{list(df.columns)}\n",
    "\n",
    "Missing Values:\n",
    "{df.isnull().sum()}\n",
    "\n",
    "Statistics:\n",
    "{df.describe(include='all')}\n",
    "\"\"\"\n",
    "\n",
    "    return summary"
   ]
  },
