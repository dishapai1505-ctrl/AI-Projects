    "#dataframe method execution tool - performs data analysis\n",
    "@tool\n",
    "def run_dataframe_method(input_text: str) -> str:\n",
    "    \"\"\"\n",
    "    Runs basic pandas-style analysis on a loaded dataset.\n",
    "\n",
    "    Input format:\n",
    "    dataset_name | method\n",
    "\n",
    "    Supported methods:\n",
    "    head, tail, columns, missing, dtypes, shape\n",
    "\n",
    "    Example:\n",
    "    styles | head\n",
    "    \"\"\"\n",
    "\n",
    "    try:\n",
    "        dataset_name, method = [x.strip() for x in input_text.split(\"|\")]\n",
    "    except:\n",
    "        return \"Use format: dataset_name | method. Example: styles | head\"\n",
    "\n",
    "    if dataset_name not in DATASETS:\n",
    "        return f\"Dataset '{dataset_name}' not found.\"\n",
    "\n",
    "    df = DATASETS[dataset_name]\n",
    "\n",
    "    if method == \"head\":\n",
    "        return str(df.head())\n",
    "\n",
    "    elif method == \"tail\":\n",
    "        return str(df.tail())\n",
    "\n",
    "    elif method == \"columns\":\n",
