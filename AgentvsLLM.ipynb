    "# creating data set tool \n",
    "from langchain.tools import tool\n",
    "\n",
    "@tool\n",
    "def list_datasets(dummy_input: str) -> str:\n",
    "    \"\"\"\n",
    "    Lists all datasets currently loaded in memory.\n",
    "\n",
    "    Input:\n",
    "    Any string. This input is ignored.\n",
    "\n",
    "    Output:\n",
    "    Available dataset names.\n",
    "    \"\"\"\n",
    "    if not DATASETS:\n",
    "        return \"No datasets loaded yet.\"\n",
    "    \n",
    "    return \"Available datasets: \" + \", \".join(DATASETS.keys())"
   ]
