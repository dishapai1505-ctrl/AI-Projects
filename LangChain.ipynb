   "source": [
    "from langchain_core.messages import HumanMessage, AIMessage\n",
    "\n",
    "chat_history = []"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d926f786",
   "metadata": {},
   "outputs": [],
   "source": [
    "country = input(\"Enter a country: \")\n",
    "\n",
    "# Chain 1\n",
    "dish = chain1.invoke({\n",
    "    \"country\": country\n",
    "})\n",
    "\n",
    "# Chain 2\n",
    "recipe = chain2.invoke({\n",
    "    \"dish\": dish\n",
    "})\n",
    "\n",
    "# Chain 3\n",
    "cooking_time = chain3.invoke({\n",
    "    \"recipe\": recipe\n",
    "})\n",
    "\n",
    "# Save conversation history\n",
    "chat_history.append(HumanMessage(content=f\"User asked for country: {country}\"))\n",
    "chat_history.append(AIMessage(content=f\"Famous dish: {dish}\"))\n",
    "chat_history.append(AIMessage(content=f\"Recipe: {recipe}\"))\n",
    "chat_history.append(AIMessage(content=f\"Cooking time: {cooking_time}\"))\n",
    "\n",
    "print(\"Country:\", country)\n",
    "print(\"Dish:\", dish)\n",
    "print(\"\\nRecipe:\\n\", recipe)\n",
    "print(\"\\nCooking Time:\", cooking_time)"
   ]
  },
