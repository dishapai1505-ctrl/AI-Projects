   "source": [
    "from langchain_core.tools import tool\n",
    "\n",
    "@tool\n",
    "def find_famous_dish(country: str) -> str:\n",
    "    \"\"\"Find the most famous dish from a country.\"\"\"\n",
    "    return chain1.invoke({\"country\": country})\n",
    "\n",
    "@tool\n",
    "def find_recipe(dish: str) -> str:\n",
    "    \"\"\"Find a recipe for a dish.\"\"\"\n",
    "    return chain2.invoke({\"dish\": dish})\n",
    "\n",
    "@tool\n",
    "def estimate_cooking_time(recipe: str) -> str:\n",
    "    \"\"\"Estimate cooking time from a recipe.\"\"\"\n",
